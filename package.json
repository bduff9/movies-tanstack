{
  "name": "movies-tanstack",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:types": "dotenv -e .env.local -- kysely-codegen --dialect mysql --out-file src/db/types.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@clerk/backend": "3.4.7",
    "@clerk/react": "6.6.2",
    "@clerk/tanstack-react-start": "1.2.3",
    "@sentry/tanstackstart-react": "10.52.0",
    "@t3-oss/env-core": "0.13.11",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-query-devtools": "5.100.9",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-router-ssr-query": "1.166.12",
    "@tanstack/react-start": "1.167.65",
    "@tanstack/router-plugin": "1.167.35",
    "arktype": "2.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "kysely": "0.29.0",
    "lucide-react": "1.14.0",
    "mysql2": "3.22.3",
    "nitro": "3.0.260429-beta",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@typescript/native-preview": "7.0.0-dev.20260510.1",
    "@biomejs/biome": "2.4.15",
    "@tanstack/devtools-vite": "0.6.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@rolldown/plugin-babel": "0.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "11.0.0",
    "jsdom": "29.1.1",
    "kysely-codegen": "0.20.0",
    "prisma": "7.8.0",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vitest": "4.1.5",
    "web-vitals": "5.2.0"
  }
}
